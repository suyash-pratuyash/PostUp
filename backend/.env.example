# ============================================
# PostUp - Environment Configuration
# ============================================
# 
# HOW TO GET YOUR FREE GEMINI API KEY:
# 
# 1. Go to https://aistudio.google.com/
# 2. Sign in with your Google account
# 3. Click "Get API Key" in the left sidebar
# 4. Click "Create API Key"
# 5. Select or create a Google Cloud project
# 6. Copy the generated API key
# 7. Paste it below and rename this file to .env
#
# NOTE: The free tier gives you ~15 RPM (requests per minute)
# which is more than enough for personal use.
# ============================================

GEMINI_API_KEY=your_api_key_here
PORT=3001
